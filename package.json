{
  "name": "resuml",
  "version": "1.13.1",
  "description": "Generate JSON resumes from YAML with theme support",
  "type": "module",
  "main": "./dist/api.js",
  "exports": {
    ".": {
      "import": "./dist/api.js",
      "require": "./dist/api.js"
    },
    "./cli": "./dist/index.js"
  },
  "bin": {
    "resuml": "./bin/resuml"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "scripts",
    "src/types"
  ],
  "scripts": {
    "build": "tsup && npm run build:builder",
    "build:lib": "tsup",
    "build:builder": "node scripts/build-builder.js",
    "dev:builder": "node scripts/dev-server.js",
    "prepublishOnly": "npm run generate:types && npm run build:lib",
    "generate:types": "node scripts/generate-types.cjs",
    "bundle:themes": "node scripts/bundle-themes.js",
    "bundle:themes:all": "node scripts/bundle-themes.js --all",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src api --ext .ts,.tsx",
    "lint:fix": "eslint src api --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release": "semantic-release",
    "prepare": "husky"
  },
  "dependencies": {
    "@jsonresume/schema": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.12.0",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "js-yaml": "^4.1.0",
    "jsonresume-theme-actual": "^0.2.2",
    "jsonresume-theme-elegant": "^1.16.1",
    "jsonresume-theme-even": "^0.26.1",
    "jsonresume-theme-kendall": "^0.2.0",
    "jsonresume-theme-paper": "^0.5.0",
    "jsonresume-theme-react": "^1.0.4",
    "jsonresume-theme-stackoverflow": "^2.1.0",
    "lodash.merge": "^4.6.2",
    "lucide-react": "^1.7.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tar": "^7.5.13",
    "yaml": "^2.3.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.3",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash.merge": "^4.6.9",
    "@types/node": "^20.11.19",
    "@types/pako": "^2.0.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "@vercel/node": "^5.7.2",
    "codemirror": "^6.0.2",
    "esbuild": "^0.28.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^9.1.7",
    "json-schema-to-typescript": "^15.0.4",
    "pako": "^2.1.0",
    "playwright": "^1.52.0",
    "prettier": "^3.0.0",
    "semantic-release": "^25.0.3",
    "tsup": "^8.0.2",
    "typescript": "^5.0.0",
    "vitest": "^3.2.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "ISC",
  "author": "phoinixi",
  "repository": {
    "type": "git",
    "url": "https://github.com/phoinixi/resuml"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
