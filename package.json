{
  "name": "resuml",
  "version": "1.20.1",
  "description": "Generate JSON resumes from YAML with theme support. CLI + MCP server for AI agents.",
  "type": "module",
  "bin": {
    "resuml": "./bin/resuml"
  },
  "files": [
    "bin",
    "dist",
    "data/skills",
    "DOCS.md",
    "README.md",
    "src/types"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run generate:types && npm run build",
    "generate:types": "node scripts/generate-types.cjs",
    "build:skills": "node scripts/build-skills-db.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release": "semantic-release",
    "prepare": "husky"
  },
  "dependencies": {
    "@jsonresume/schema": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "glob": "^13.0.0",
    "lodash.merge": "^4.6.2",
    "yaml": "^2.3.4",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "playwright": "^1.52.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.3",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@types/lodash.merge": "^4.6.9",
    "@types/node": "^20.11.19",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^9.1.7",
    "json-schema-to-typescript": "^15.0.4",
    "playwright": "^1.52.0",
    "prettier": "^3.0.0",
    "semantic-release": "^25.0.3",
    "tsup": "^8.0.2",
    "typescript": "^5.0.0",
    "vitest": "^3.2.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "ISC",
  "author": "phoinixi",
  "repository": {
    "type": "git",
    "url": "https://github.com/phoinixi/resuml"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "resume",
    "cv",
    "yaml",
    "json-resume",
    "ats",
    "cli",
    "mcp"
  ]
}
