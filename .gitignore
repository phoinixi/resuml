# Dependencies
node_modules/
.pnp
.pnp.js

# Builder output
docs/app/*
!docs/app/main.js
# Theme bundles: tracked in git so they're available in deployed docs/
# Large temporary theme cache files are NOT tracked:
docs/themes/_entry_*.js

# Build outputs
dist/
build/
lib/
.next/
out/
.nuxt/

# Test coverage
coverage/
.nyc_output/

# TypeScript
*.tsbuildinfo
.tsbuildinfo

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

