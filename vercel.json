{
  "buildCommand": "npm run build",
  "outputDirectory": "docs",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/render.ts": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/pdf.ts": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/themes.ts": {
      "memory": 256,
      "maxDuration": 10
    }
  }
}
